{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "whale-landings",
  "main": "./custom-worker.ts",
  "compatibility_date": "2025-09-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "placement": { "mode": "smart" },
  "workers_dev": true,
  "preview_urls": true,
  // KV namespace for tenant configs (hostname → JSON config)
  // Create with: wrangler kv namespace create TENANTS_KV
  "kv_namespaces": [
    {
      "binding": "TENANTS_KV",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "whale-landings-cache"
    }
  ],
  "vars": {
    // Default CRM webhook — can be overridden per tenant in KV config
    "CRM_WEBHOOK_URL": "https://YOUR_WHALEBIZCRM_URL/api/leads",
    "NEXT_PUBLIC_BASE_URL": "https://landings.whaledigital.co.il"
  },
  "env": {
    "preview": {
      "name": "whale-landings-preview",
      "routes": [],
      "workers_dev": true,
      "kv_namespaces": [
        {
          "binding": "TENANTS_KV",
          "id": "REPLACE_WITH_KV_NAMESPACE_PREVIEW_ID"
        }
      ],
      "r2_buckets": [
        {
          "binding": "NEXT_INC_CACHE_R2_BUCKET",
          "bucket_name": "whale-landings-cache-preview"
        }
      ],
      "vars": {
        "CRM_WEBHOOK_URL": "https://YOUR_WHALEBIZCRM_URL/api/leads",
        "NEXT_PUBLIC_BASE_URL": "https://preview.whaledigital.co.il"
      }
    }
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    }
  }
}
